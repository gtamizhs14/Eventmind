# EventMind — copy to .env and fill in values
# Never commit .env to git

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
ENV=development           # development | production
LOG_LEVEL=debug           # debug | info | warn | error

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Supported providers: claude (default), groq, openai
# Only these two vars need to change to switch providers
LLM_PROVIDER=claude
LLM_API_KEY=

# Override the model (optional — each provider has a sensible default)
#   claude default: claude-3-5-sonnet-20241022
#   groq   default: llama-3.3-70b-versatile
#   openai default: gpt-4o-mini
LLM_MODEL=

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Local dev: docker-compose starts Kafka at localhost:9094
# Confluent Cloud: bootstrap.servers from your cluster settings
KAFKA_BROKERS=localhost:9094
KAFKA_GROUP_ID=eventmind-consumer
KAFKA_TOPIC_EVENTS=events
KAFKA_TOPIC_DLQ=events.dlq

# Confluent Cloud SASL credentials (leave empty for local dev)
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_USE_TLS=false       # set true for Confluent Cloud

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Local dev: docker-compose starts postgres at localhost:5432
DATABASE_URL=postgres://eventmind:eventmind@localhost:5432/eventmind?sslmode=disable
# Supabase (prod): postgres://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_MAX_CONNS=10

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=eventmind

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev: docker-compose starts Redis at localhost:6379
REDIS_URL=redis://localhost:6379
# Upstash (prod): rediss://default:[token]@[endpoint].upstash.io:6379

# ── Metrics ───────────────────────────────────────────────────────────────────
METRICS_PORT=9091         # Prometheus scrape endpoint (separate from API port)

# ── Retry worker ──────────────────────────────────────────────────────────────
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_DELAY_MS=1000  # exponential: 1s → 2s → 4s → 8s → 16s
