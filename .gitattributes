# Normalize line endings to LF in the repo, checkout as-is on Windows
* text=auto eol=lf

# Force LF for files that must not have CRLF
*.go    text eol=lf
*.sh    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.tf    text eol=lf
*.md    text eol=lf
*.json  text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf
